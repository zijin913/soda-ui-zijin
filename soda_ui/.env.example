# soda_ui — environment overrides
#
# The UI defaults to using the page's own hostname for both backend and launcher
# (launcher on :8079, backend on :8080). Override only if they live elsewhere.
#
# VITE_LAUNCHER_URL=http://soma:8079
# VITE_BACKEND_URL=http://soma:8080
# VITE_WS_URL=ws://soma:8080/ws
