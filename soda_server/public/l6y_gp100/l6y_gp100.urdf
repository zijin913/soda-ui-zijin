<?xml version="1.0" encoding="utf-8"?>
<!-- Archer L6Y arm with GP100 gripper (merged URDF) -->
<!-- Based on MuJoCo model structure for correct kinematics -->
<robot name="archer_l6y_gp100">
    <!-- ==================== ARM LINKS ==================== -->
    <link name="base_link">
        <inertial>
            <origin xyz="-0.00080975 0.00005863 0.05684460" rpy="0 0 0" />
            <mass value="0.61800543" />
            <inertia ixx="0.00055618" ixy="-0.00000009" ixz="-0.00000663" iyy="0.00058624" iyz="0.00000086" izz="0.00060508" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/base_link.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/base_link.STL" />
            </geometry>
        </collision>
    </link>

    <link name="link_1">
        <inertial>
            <origin xyz="0.00884023 -0.00039740 0.03457242" rpy="0 0 0" />
            <mass value="0.29593000" />
            <inertia ixx="0.00047871" ixy="0.00000088" ixz="-0.00005799" iyy="0.00030053" iyz="0.00000258" izz="0.00041726" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_1.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_1.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_1" type="revolute">
        <origin xyz="0 0 0.08355" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="link_1" />
        <axis xyz="0 0 1" />
        <limit lower="-2.8623" upper="2.8623" effort="1" velocity="1" />
    </joint>

    <link name="link_2">
        <inertial>
            <origin xyz="-0.00159885 0.02740310 0.13379837" rpy="0 0 0" />
            <mass value="1.34359000" />
            <inertia ixx="0.01905633" ixy="0.00000078" ixz="0.00001635" iyy="0.01890424" iyz="0.00000765" izz="0.00086433" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_2.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_2.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_2" type="revolute">
        <origin xyz="0.02 -0.0285 0.0555" rpy="0 0 0" />
        <parent link="link_1" />
        <child link="link_2" />
        <axis xyz="0 1 0" />
        <limit lower="-2.0943" upper="1.5707" effort="1" velocity="1" />
    </joint>

    <link name="link_3">
        <inertial>
            <origin xyz="-0.05454198 0.02770576 0.14631127" rpy="0 0 0" />
            <mass value="1.08626000" />
            <inertia ixx="0.01172853" ixy="-0.00000662" ixz="0.00163495" iyy="0.01182587" iyz="0.00007450" izz="0.00147592" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_3.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_3.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_3" type="revolute">
        <origin xyz="0 0 0.27" rpy="0 0 0" />
        <parent link="link_2" />
        <child link="link_3" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="3.159" effort="1" velocity="1" />
    </joint>

    <link name="link_4">
        <inertial>
            <origin xyz="-0.04639218 0.02832840 0.04493954" rpy="0 0 0" />
            <mass value="0.53458000" />
            <inertia ixx="0.00085129" ixy="0.00000633" ixz="0.00043133" iyy="0.00109396" iyz="-0.00000547" izz="0.00087351" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_4.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_4.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_4" type="revolute">
        <origin xyz="-0.065 0 0.25" rpy="0 0 0" />
        <parent link="link_3" />
        <child link="link_4" />
        <axis xyz="0 1 0" />
        <limit lower="-1.5707" upper="1.5707" effort="1" velocity="1" />
    </joint>

    <link name="link_5">
        <inertial>
            <origin xyz="0.04082486 0.00006149 0.00717093" rpy="0 0 0" />
            <mass value="0.38996000" />
            <inertia ixx="0.00016500" ixy="-0.00000021" ixz="-0.00002287" iyy="0.00022995" iyz="0.00000039" izz="0.00021724" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_5.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_5.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_5" type="revolute">
        <origin xyz="-0.046 0.0285 0.065" rpy="0 0 0" />
        <parent link="link_4" />
        <child link="link_5" />
        <axis xyz="-1 0 0" />
        <limit lower="-1.5707" upper="1.5707" effort="1" velocity="1" />
    </joint>

    <link name="link_6">
        <inertial>
            <origin xyz="-0.0009 0.0001 0.0596" rpy="0 0 0" />
            <mass value="0.6760" />
            <inertia ixx="0.0011" ixy="0" ixz="0" iyy="0.0011" iyz="0" izz="0.0004" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_6.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/link_6.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_6" type="revolute">
        <origin xyz="0.046 0 0.034" rpy="0 0 0" />
        <parent link="link_5" />
        <child link="link_6" />
        <axis xyz="0 0 1" />
        <limit lower="-3.1415" upper="3.1415" effort="0" velocity="0" />
    </joint>

    <!-- ==================== GRIPPER LINKS ==================== -->
    <!-- Gripper base attached to link_6 -->
    <!-- L6Y link_6 length ~60mm, gripper attaches at end -->
    <link name="gripper_base_link">
        <inertial>
            <origin xyz="0.042219 0.0 0.011623" rpy="0 0 0" />
            <mass value="0.283322" />
            <inertia ixx="0.000242" ixy="0" ixz="0.000004" iyy="0.000255" iyz="0" izz="0.000177" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_base_link.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_base_link.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_base_joint" type="fixed">
        <!-- L6Y has 6 arm links, gripper attaches directly to link_6 end -->
        <!-- MuJoCo Y6 only has 5 arm links (joint_6 is gripper rotation) -->
        <origin xyz="0 0 0" rpy="0 -1.5708 0" />
        <parent link="link_6" />
        <child link="gripper_base_link" />
    </joint>

    <!-- Camera link -->
    <link name="gripper_camera_link">
        <inertial>
            <origin xyz="0.0102 -0.00006 -0.00619" rpy="0 0 0" />
            <mass value="0.120826" />
            <inertia ixx="0.000057" ixy="0" ixz="0.000028" iyy="0.000074" iyz="0" izz="0.000027" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_camera.STL" />
            </geometry>
            <material name="">
                <color rgba="0.667 0.698 0.769 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_camera.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_camera_joint" type="fixed">
        <origin xyz="0.0404 0 0.1201" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="gripper_camera_link" />
    </joint>

    <!-- ==================== LEFT FINGER (serial chain with mimic) ==================== -->
    <!-- Left link 1 (driven joint) -->
    <link name="gripper_left_link_1">
        <inertial>
            <origin xyz="0.00299 0.02326 -0.00005" rpy="0 0 0" />
            <mass value="0.00595" />
            <inertia ixx="0.0000027" ixy="0.0000002" ixz="0" iyy="0.0000015" iyz="0" izz="0.0000013" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_2.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_2.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_left_joint_1" type="revolute">
        <origin xyz="0.0721 0.014 0.000025" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="gripper_left_link_1" />
        <axis xyz="0 0 -1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
    </joint>

    <!-- Left link 2 (fingertip, connected to link_1) -->
    <link name="gripper_left_link_2">
        <inertial>
            <origin xyz="0.0255 0.00915 -0.00176" rpy="0 0 0" />
            <mass value="0.0339" />
            <inertia ixx="0.0000043" ixy="-0.0000029" ixz="0" iyy="0.0000128" iyz="0" izz="0.0000136" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_3.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_3.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_left_joint_2" type="revolute">
        <origin xyz="0.0085108 0.04927 0" rpy="0 0 0" />
        <parent link="gripper_left_link_1" />
        <child link="gripper_left_link_2" />
        <axis xyz="0 0 1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
        <mimic joint="gripper_left_joint_1" multiplier="1.0" offset="0" />
    </joint>

    <!-- Left helper link (parallel linkage) -->
    <link name="gripper_left_helper_link">
        <inertial>
            <origin xyz="0.00299 0.02326 -0.00005" rpy="0 0 0" />
            <mass value="0.00595" />
            <inertia ixx="0.0000027" ixy="0.0000002" ixz="0" iyy="0.0000015" iyz="0" izz="0.0000013" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_1.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_1.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_left_helper_joint" type="revolute">
        <origin xyz="0.057667 0.030604 0.000025" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="gripper_left_helper_link" />
        <axis xyz="0 0 -1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
        <mimic joint="gripper_left_joint_1" multiplier="1.0" offset="0" />
    </joint>

    <!-- ==================== RIGHT FINGER (serial chain with mimic) ==================== -->
    <!-- Right link 1 (driven joint) -->
    <link name="gripper_right_link_1">
        <inertial>
            <origin xyz="0.00299 -0.02326 -0.00005" rpy="0 0 0" />
            <mass value="0.00595" />
            <inertia ixx="0.0000027" ixy="-0.0000002" ixz="0" iyy="0.0000015" iyz="0" izz="0.0000013" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_5.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_5.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_right_joint_1" type="revolute">
        <origin xyz="0.0721 -0.014 0.000025" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="gripper_right_link_1" />
        <axis xyz="0 0 1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
        <mimic joint="gripper_left_joint_1" multiplier="1.0" offset="0" />
    </joint>

    <!-- Right link 2 (fingertip, connected to link_1) -->
    <link name="gripper_right_link_2">
        <inertial>
            <origin xyz="0.0255 -0.00915 -0.00176" rpy="0 0 0" />
            <mass value="0.0339" />
            <inertia ixx="0.0000043" ixy="0.0000029" ixz="0" iyy="0.0000128" iyz="0" izz="0.0000136" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_6.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_6.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_right_joint_2" type="revolute">
        <origin xyz="0.0085108 -0.04927 0" rpy="0 0 0" />
        <parent link="gripper_right_link_1" />
        <child link="gripper_right_link_2" />
        <axis xyz="0 0 -1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
        <mimic joint="gripper_left_joint_1" multiplier="1.0" offset="0" />
    </joint>

    <!-- Right helper link (parallel linkage) -->
    <link name="gripper_right_helper_link">
        <inertial>
            <origin xyz="0.00299 -0.02326 -0.00005" rpy="0 0 0" />
            <mass value="0.00595" />
            <inertia ixx="0.0000027" ixy="-0.0000002" ixz="0" iyy="0.0000015" iyz="0" izz="0.0000013" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_4.STL" />
            </geometry>
            <material name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="./meshes/gp100_link_4.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="gripper_right_helper_joint" type="revolute">
        <origin xyz="0.057667 -0.030604 0.000025" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="gripper_right_helper_link" />
        <axis xyz="0 0 1" />
        <limit lower="0" upper="1.52" effort="5" velocity="2" />
        <mimic joint="gripper_left_joint_1" multiplier="1.0" offset="0" />
    </joint>

    <!-- End effector frame (TCP) -->
    <link name="ee_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.001" />
            <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
        </inertial>
    </link>
    <joint name="ee_joint" type="fixed">
        <!-- TCP at 187mm from gripper base (fingertip position) -->
        <origin xyz="0.187 0 0" rpy="0 0 0" />
        <parent link="gripper_base_link" />
        <child link="ee_link" />
    </joint>

</robot>
